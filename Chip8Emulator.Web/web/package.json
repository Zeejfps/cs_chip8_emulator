{
  "name": "chip8-wasm-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "predev": "dotnet build ../Chip8Emulator.Web.csproj -p:SKIP_FRONTEND_BUILD=true",
    "dev": "vite",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json --watch",
    "fetch-roms": "node scripts/fetch-roms.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.{ts,svelte,js,mjs,css,json,html}": "prettier --write"
  },
  "devDependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@internationalized/date": "^3.12.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "clsx": "^2.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "phosphor-svelte": "^3.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.4.2"
  },
  "dependencies": {
    "bits-ui": "^2.18.0",
    "lucide-svelte": "^1.0.1"
  }
}
