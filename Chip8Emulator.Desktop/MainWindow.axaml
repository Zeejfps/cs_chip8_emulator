<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Chip8Emulator.Desktop"
        x:Class="Chip8Emulator.Desktop.MainWindow"
        Width="640" Height="360"
        Title="Chip8 Emulator"
        Background="Black">

    <DockPanel LastChildFill="True">

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open ROM…"
                          Click="OnOpenRom"
                          InputGesture="Ctrl+O" />
                <MenuItem x:Name="RecentRomsMenu" Header="_Recent ROMs" />
                <Separator />
                <MenuItem Header="E_xit" Click="OnExit" />
            </MenuItem>
            <MenuItem Header="_Emulation">
                <MenuItem x:Name="PauseMenuItem"
                          Header="_Pause"
                          Click="OnPause"
                          InputGesture="Escape" />
                <MenuItem Header="_Reset"
                          Click="OnReset"
                          InputGesture="F5" />
                <Separator />
                <MenuItem Header="_Quirks…" Click="OnQuirks" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Fullscreen"
                          Click="OnFullscreen"
                          InputGesture="F11" />
            </MenuItem>
        </Menu>

        <local:EmulatorView x:Name="Viewport" Focusable="True" />

    </DockPanel>
</Window>
